# --- DATABASE CONFIGURATION ---
# En local (Docker Compose), el host debe ser "postgres"
# En Railway, esta URI se reemplazará por la variable ${{Postgres.RAILWAY_INTERNAL_URL}}
POSTGRES_URI=postgresql://user:password@postgres:5432/hwc_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=hwc_db

# --- STORAGE (SUPABASE) ---
# Sustituir con las credenciales de tu proyecto de Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# --- EMAIL SERVICE (SMTP) ---
# Si usas Gmail, recuerda generar una "App Password" de 16 caracteres
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu_app_password_aqui
SMTP_FROM_EMAIL=tu-email@gmail.com
SMTP_FROM_NAME=Hello World Cup

# --- APPLICATION SETTINGS ---
# Cambiar a 'production' al desplegar en Railway
ENVIRONMENT=development
CLEAR_EXISTING_DATA_FOR_DEVELOPMENT=false